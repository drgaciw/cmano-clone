# Copy to `.env` for local tooling (never commit `.env`).
# Paste the same value into Buildkite → Pipeline → Environment.
# Create at https://app.graphite.com/settings/ci
GRAPHITE_CI_OPTIMIZER_TOKEN=

# Optional — GitNexus wiki on Buildkite. Hindsight now runs project-local
# without an API key by default.
OPENAI_API_KEY=
