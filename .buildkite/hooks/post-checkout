#!/usr/bin/env bash
# When the pipeline UI follows default-branch YAML, Graphite optimizer can --replace
# with empty steps and skip :hammer:. Upload this commit's pipeline after checkout so
# PR/stack builds use branch .buildkite/pipeline.yml (build-first, no Graphite plugin).
set -euo pipefail

if [[ ! -f .buildkite/pipeline.yml ]]; then
  exit 0
fi

if ! command -v buildkite-agent >/dev/null 2>&1; then
  exit 0
fi

# Only replace once per build (first checkout).
if [[ -n "${BUILDKITE_PIPELINE_OVERRIDE_DONE:-}" ]]; then
  exit 0
fi

export BUILDKITE_PIPELINE_OVERRIDE_DONE=1
buildkite-agent pipeline upload .buildkite/pipeline.yml --replace
