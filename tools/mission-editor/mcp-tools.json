        "--lat",
        "${lat}",
        "--lon",
        "${lon}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "unitId", "sideId", "platformId", "lat", "lon"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "unitId": { "type": "string" },
          "sideId": { "type": "string" },
          "platformId": { "type": "string" },
          "lat": { "type": "number" },
          "lon": { "type": "number" }
        }
      }
    },
    {
      "name": "orbat_move_unit",
      "description": "Move an existing ORBAT unit to a new lat/lon (preserves non-position fields).",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "orbat_move_unit",
