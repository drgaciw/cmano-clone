        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "unitId": { "type": "string" },
          "lat": { "type": "number" },
          "lon": { "type": "number" }
        }
      }
    },
    {
      "name": "orbat_clone_unit",
      "description": "Clone an existing ORBAT unit under a new id at the given position.",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "orbat_clone_unit",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--source",
        "${sourceUnitId}",
        "--id",
        "${unitId}",
        "--lat",
        "${lat}",
        "--lon",
        "${lon}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "sourceUnitId", "unitId", "lat", "lon"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "sourceUnitId": { "type": "string" },
          "unitId": { "type": "string" },
          "lat": { "type": "number" },
          "lon": { "type": "number" }
        }
      }
    },
    {
      "name": "reference_point_upsert",
      "description": "Insert or replace a reference point (point/line/polygon/circle) by id.",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "reference_point_upsert",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${referencePointId}",
        "--type",
        "${type}",
        "--latlon",
        "${latlon}",
        "--radius-nm",
        "${radiusNm}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "referencePointId", "type", "latlon"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "referencePointId": { "type": "string" },
          "type": { "type": "string", "enum": ["point", "line", "polygon", "circle"] },
          "latlon": { "type": "string", "description": "lat,lon vertex (repeatable via host)" },
          "radiusNm": { "type": "number", "description": "Optional radius in nautical miles (circle)" }
        }
      }
    },
