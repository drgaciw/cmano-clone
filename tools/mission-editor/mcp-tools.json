{
  "schemaVersion": 2,
  "description": "Headless mission-editor MCP tool bindings (Unity-MCP host registers these commands).",
  "tools": [
    {
      "name": "scenario_create",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "scenario_create",
        "-ExtraArgs",
        "--out",
        "${scenarioPath}",
        "--db-ref",
        "${dbRef}",
        "--policy-id",
        "${policyId}",
        "--seed",
        "${seed}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "dbRef": { "type": "string", "default": "baltic_patrol" },
          "policyId": { "type": "string", "default": "baltic-patrol-catalog" },
          "seed": { "type": "integer", "default": 42 }
        }
      }
    },
    {
      "name": "mission_add_patrol",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_add_patrol",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}",
        "--unit",
        "${unitId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId", "unitId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" },
          "unitId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_add_strike",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_add_strike",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}",
        "--unit",
        "${unitId}",
        "--target",
        "${targetId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId", "unitId", "targetId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" },
          "unitId": { "type": "string" },
          "targetId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_update_patrol",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_update_patrol",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_update_strike",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_update_strike",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_delete",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_delete",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_plan_suggest",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_plan_suggest",
        "-ExtraArgs",
        "--intent",
        "${intent}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["intent"],
        "properties": {
          "intent": { "type": "string" }
        }
      },
      "returns": "JSON suggestions for mission_add_* tools"
    },
    {
      "name": "scenario_cyber_status",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "scenario_cyber_status",
        "-ExtraArgs",
        "--policy",
        "${policyId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["policyId"],
        "properties": {
          "policyId": { "type": "string" }
        }
      },
      "returns": "JSON cyber abort codes and comms coupling hints"
    },
    {
      "name": "scenario_near_future_spawn",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "scenario_near_future_spawn",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string" }
        }
      },
      "returns": "JSON gated near-future spawn plan (CCA / hypersonic)"
    },
    {
      "name": "scenario_comms_status",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "scenario_comms_status",
        "-ExtraArgs",
        "--policy",
        "${policyId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["policyId"],
        "properties": {
          "policyId": { "type": "string", "description": "Scenario policy id (e.g. baltic-patrol-comms)" }
        }
      },
      "returns": "JSON comms display settings and timeline transitions"
    },
    {
      "name": "scenario_validate",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-ScenarioValidate.ps1", "-ScenarioPath", "${scenarioPath}"],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string", "description": "Repo-relative path to canonical scenario.json" }
        }
      },
      "returns": "JSON ValidationReport (passed, canExport, reportHash, findings)"
    },
    {
      "name": "scenario_export_brief",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-ScenarioValidate.ps1", "-ScenarioPath", "${scenarioPath}", "-ExportBrief"],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string" }
        }
      }
    },
    {
      "name": "scenario_simulate_sample",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-ScenarioSimulateSample.ps1", "-ScenarioPath", "${scenarioPath}", "-Ticks", "${ticks}"],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "ticks": { "type": "integer", "default": 32, "minimum": 1 }
        }
      },
      "returns": "JSON sample summary (worldHash, fingerprint, engagementCount); exit 1 if validation blocks"
    }
  ]
}