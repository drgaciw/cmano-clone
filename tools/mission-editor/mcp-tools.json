{
  "schemaVersion": 2,
  "description": "Headless mission-editor MCP tool bindings (Unity-MCP host registers these commands).",
  "tools": [
    {
      "name": "scenario_create",
      "description": "Create a new canonical scenario document (headless; emits editorState derived). S86-01 polished.",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "scenario_create",
        "-ExtraArgs",
        "--out",
        "${scenarioPath}",
        "--db-ref",
        "${dbRef}",
        "--policy-id",
        "${policyId}",
        "--seed",
        "${seed}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string", "description": "Output path for new .scenario.json" },
          "dbRef": { "type": "string", "default": "baltic_patrol" },
          "policyId": { "type": "string", "default": "baltic-patrol-catalog" },
          "seed": { "type": "integer", "default": 42 }
        }
      },
      "returns": "Path to created scenario (schemaVersion 2 contract)"
    },
    {
      "name": "mission_add_patrol",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_add_patrol",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}",
        "--unit",
        "${unitId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId", "unitId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" },
          "unitId": { "type": "string" }
        }
      }
    },
    {
      "name": "orbat_upsert_unit",
