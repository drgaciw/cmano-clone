{
  "schemaVersion": 2,
  "description": "Headless mission-editor MCP tool bindings (Unity-MCP host registers these commands).",
  "tools": [
    {
      "name": "scenario_create",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "scenario_create",
        "-ExtraArgs",
        "--out",
        "${scenarioPath}",
        "--db-ref",
        "${dbRef}",
        "--policy-id",
        "${policyId}",
        "--seed",
        "${seed}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "dbRef": { "type": "string", "default": "baltic_patrol" },
          "policyId": { "type": "string", "default": "baltic-patrol-catalog" },
          "seed": { "type": "integer", "default": 42 }
        }
      }
    },
    {
      "name": "mission_add_patrol",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_add_patrol",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}",
        "--unit",
        "${unitId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId", "unitId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" },
          "unitId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_add_strike",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_add_strike",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}",
        "--unit",
        "${unitId}",
        "--target",
        "${targetId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId", "unitId", "targetId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" },
          "unitId": { "type": "string" },
          "targetId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_update_patrol",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_update_patrol",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_update_strike",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_update_strike",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_delete",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_delete",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}",
        "--edit-version",
        "${editVersion}",
        "--id",
        "${missionId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath", "editVersion", "missionId"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "editVersion": { "type": "integer" },
          "missionId": { "type": "string" }
        }
      }
    },
    {
      "name": "mission_plan_suggest",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "mission_plan_suggest",
        "-ExtraArgs",
        "--intent",
        "${intent}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["intent"],
        "properties": {
          "intent": { "type": "string" }
        }
      },
      "returns": "JSON suggestions for mission_add_* tools"
    },
    {
      "name": "scenario_cyber_status",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "scenario_cyber_status",
        "-ExtraArgs",
        "--policy",
        "${policyId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["policyId"],
        "properties": {
          "policyId": { "type": "string" }
        }
      },
      "returns": "JSON cyber abort codes and comms coupling hints"
    },
    {
      "name": "scenario_near_future_spawn",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "scenario_near_future_spawn",
        "-ExtraArgs",
        "--path",
        "${scenarioPath}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string" }
        }
      },
      "returns": "JSON gated near-future spawn plan (CCA / hypersonic)"
    },
    {
      "name": "scenario_comms_status",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "scenario_comms_status",
        "-ExtraArgs",
        "--policy",
        "${policyId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["policyId"],
        "properties": {
          "policyId": { "type": "string", "description": "Scenario policy id (e.g. baltic-patrol-comms)" }
        }
      },
      "returns": "JSON comms display settings and timeline transitions"
    },
    {
      "name": "scenario_validate",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-ScenarioValidate.ps1", "-ScenarioPath", "${scenarioPath}"],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string", "description": "Repo-relative path to canonical scenario.json" }
        }
      },
      "returns": "JSON ValidationReport (passed, canExport, reportHash, findings)"
    },
    {
      "name": "scenario_export_brief",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-ScenarioValidate.ps1", "-ScenarioPath", "${scenarioPath}", "-ExportBrief"],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string" }
        }
      }
    },
    {
      "name": "scenario_simulate_sample",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-ScenarioSimulateSample.ps1", "-ScenarioPath", "${scenarioPath}", "-Ticks", "${ticks}"],
      "inputSchema": {
        "type": "object",
        "required": ["scenarioPath"],
        "properties": {
          "scenarioPath": { "type": "string" },
          "ticks": { "type": "integer", "default": 32, "minimum": 1 }
        }
      },
      "returns": "JSON sample summary (worldHash, fingerprint, engagementCount); exit 1 if validation blocks"
    },
    {
      "name": "osint_search",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-MissionEditorMcp.ps1", "-Command", "osint_search", "-ExtraArgs", "--db", "${db}"],
      "inputSchema": {
        "type": "object",
        "properties": {
          "db": { "type": "string" }
        }
      },
      "returns": "JSON with proposals (from FileOsintConnector + runner) and logOnlyCount (S21 MCP search_osint per req05)"
    },
    {
      "name": "osint_list_staging_proposals",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-MissionEditorMcp.ps1", "-Command", "osint_staging_review", "-ExtraArgs", "--db", "${db}"],
      "inputSchema": {
        "type": "object",
        "required": ["db"],
        "properties": {
          "db": { "type": "string" }
        }
      },
      "returns": "JSON pending proposals (reuses S20 osint_staging_review for list_staging_proposals)"
    },
    {
      "name": "osint_digest",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-MissionEditorMcp.ps1", "-Command", "osint_search", "-ExtraArgs", "--db", "${db}"],
      "inputSchema": { "type": "object", "properties": { "db": { "type": "string" } } }
    },
    {
      "name": "osint_get_proposal_detail",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-MissionEditorMcp.ps1", "-Command", "osint_staging_review", "-ExtraArgs", "--db", "${db}"],
      "inputSchema": { "type": "object", "properties": { "db": { "type": "string" } } }
    },
    {
      "name": "osint_submit_review_decision",
      "command": "pwsh",
      "args": ["-File", "tools/mission-editor/Invoke-MissionEditorMcp.ps1", "-Command", "osint_staging_review", "-ExtraArgs", "--db", "${db}", "--approve", "${batchId}"],
      "inputSchema": { "type": "object", "properties": { "db": { "type": "string" }, "batchId": { "type": "string" } } }
    },
    {
      "name": "platform_export_xlsx",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "platform_export_xlsx",
        "-ExtraArgs",
        "--db",
        "${dbRef}",
        "--out",
        "${outPath}",
        "--snapshot",
        "${snapshotId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["outPath"],
        "properties": {
          "dbRef": { "type": "string", "default": "baltic_patrol" },
          "outPath": { "type": "string" },
          "snapshotId": { "type": "string", "default": "" }
        }
      },
      "returns": "JSON status + workbook (canonical text for headless roundtrip; xlsx adapter deferred per ADR-011)"
    },
    {
      "name": "platform_import_xlsx",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "platform_import_xlsx",
        "-ExtraArgs",
        "--db",
        "${dbRef}",
        "--in",
        "${inPath}",
        "--actor-type",
        "${actorType}",
        "--actor-id",
        "${actorId}"
      ],
      "inputSchema": {
        "type": "object",
        "required": ["dbRef"],
        "properties": {
          "dbRef": { "type": "string" },
          "inPath": { "type": "string" },
          "actorType": { "type": "string", "default": "cli" },
          "actorId": { "type": "string", "default": "mcp" }
        }
      },
      "returns": "JSON {ok, verb, staged, notes, nextStep: catalog_write_approve}; uses IWriteGate (no auto-commit)"
    },
    {
      "name": "platform_diff_xlsx",
      "command": "pwsh",
      "args": [
        "-File",
        "tools/mission-editor/Invoke-MissionEditorMcp.ps1",
        "-Command",
        "platform_diff_xlsx",
        "-ExtraArgs",
        "--db",
        "${dbRef}",
        "--base",
        "${basePath}",
        "--edited",
        "${editedPath}"
      ],
      "inputSchema": {
        "type": "object",
        "required": [],
        "properties": {
          "dbRef": { "type": "string", "default": "baltic_patrol" },
          "basePath": { "type": "string" },
          "editedPath": { "type": "string" }
        }
      },
      "returns": "JSON diff report (change count + determinism note)"
    }
  ]
}