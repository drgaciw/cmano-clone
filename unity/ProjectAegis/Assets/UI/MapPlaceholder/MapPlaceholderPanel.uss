    background-position-x: -48px;
    background-position-y: 0px;
}

.map-app6-frame--neutral {
    width: 16px;
    height: 16px;
    margin-right: 4px;
    background-image: url("project://database/Assets/UI/MapPlaceholder/App6FrameAtlas.png");
    -unity-background-scale-mode: stretch-to-fill;
    background-size: 112px 16px;
    background-position-x: -64px;
    background-position-y: 0px;
}

.map-app6-frame--suspect {
    width: 16px;
    height: 16px;
    margin-right: 4px;
    background-image: url("project://database/Assets/UI/MapPlaceholder/App6FrameAtlas.png");
    -unity-background-scale-mode: stretch-to-fill;
    background-size: 112px 16px;
    background-position-x: -80px;
